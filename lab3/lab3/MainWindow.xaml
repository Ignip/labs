<Window x:Class="lab3.MainWindow"
        
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Умный дом" Height="300" Width="400">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

       
        <TextBlock x:Name="RoomNameText" Grid.Row="0" Grid.Column="1" Text="Кухня" FontWeight="Bold" Margin="53,0,0,13" FontSize="24"/>

    
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Температура:" Margin="-2,37,13,139" Grid.RowSpan="2"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="81,37,2,139" Grid.ColumnSpan="2" Grid.RowSpan="2">
            <TextBlock x:Name="TemperatureText" Text="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="°C" VerticalAlignment="Center"/>
        </StackPanel>

        
        <Slider x:Name="TemperatureSlider" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                Minimum="-2" Maximum="40" Value="18"
                ValueChanged="TemperatureSlider_ValueChanged"
                Margin="35,1,26,19"/>

        
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Свет:" VerticalAlignment="Center" Margin="0,0,10,0"/>
        <CheckBox x:Name="LightCheckBox" Grid.Row="3" Grid.Column="1" 
                  Content="Включить свет"
                  Checked="LightCheckBox_Checked" 
                  Unchecked="LightCheckBox_Unchecked"
                  VerticalAlignment="Center"/>

    </Grid>
</Window>