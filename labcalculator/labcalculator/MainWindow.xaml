<Window x:Class="labcalculator.MainWindow"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:labcalculator"
        mc:Ignorable="d"
       Title="Calculator" Height = "300" Width="200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Button Grid.Row="1" Grid.Column="0"  Content="7" FontSize="30" Click="NumberButton_Click"></Button>
        <Button Grid.Row="1" Grid.Column="1"  Content="8" FontSize="30" Click="NumberButton_Click"></Button>
        <Button Grid.Row="1" Grid.Column="2"  Content="9" FontSize="30" Click="NumberButton_Click"></Button>
        <Button Grid.Row="1" Grid.Column="3"  Content="/" FontSize="30" Click="OperatorButton_Click"></Button>
        <Button Grid.Row="2" Grid.Column="0"  Content="4" FontSize="30" Click="NumberButton_Click"></Button>
        <Button Grid.Row="2" Grid.Column="1"  Content="5" FontSize="30" Click="NumberButton_Click"></Button>
        <Button Grid.Row="2" Grid.Column="2"  Content="6" FontSize="30" Click="NumberButton_Click"></Button>
        <Button Grid.Row="2" Grid.Column="3"  Content="*" FontSize="30" Click="OperatorButton_Click"></Button>
        <Button Grid.Row="3" Grid.Column="0"  Content="1" FontSize="30" Click="NumberButton_Click"></Button>
        <Button Grid.Row="3" Grid.Column="1"  Content="2" FontSize="30" Click="NumberButton_Click"></Button>
        <Button Grid.Row="3" Grid.Column="2" Content="3" FontSize="30" Click="NumberButton_Click"></Button>
        <Button Grid.Row="3" Grid.Column="3" Content="-" FontSize="30" Click="OperatorButton_Click"></Button>
        <Button Grid.Row="4" Grid.Column="0"  Content="0" FontSize="30" Click="NumberButton_Click"></Button>
        <Button Grid.Row="4" Grid.Column="1"  Content="C" FontSize="30" Click="ClearButton_Click"></Button>
        <Button Grid.Row="4" Grid.Column="2" Content="=" FontSize="30" Click="EqualsButton_Click"></Button>
        <Button Grid.Row="4" Grid.Column="3"  Content="+" FontSize="30" Click="OperatorButton_Click"></Button>
        <TextBlock x:Name="DisplayTextBox" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" Text="" Margin="10,2,10,57" Grid.RowSpan="2"/>
    </Grid>
</Window>
